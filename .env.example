# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # Edge Functions + server only — never expose to client
SUPABASE_JWT_SECRET=                # For manual JWT verify in Razorpay webhook

# ─── MSG91 ───────────────────────────────────────────────────────────────────
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID_OTP=              # Flow ID for OTP template
MSG91_SENDER_ID=Saloo
MSG91_WHATSAPP_TEMPLATE_BOOKING=    # WhatsApp template name for booking confirmation
MSG91_WHATSAPP_TEMPLATE_REMINDER=   # WhatsApp template name for appointment reminder

# ─── Razorpay ────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_ACCOUNT_NUMBER=            # Saloo platform account (for Razorpay Route)

# ─── Firebase (FCM push notifications) ───────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=      # Stringified JSON of service account

# ─── Google Maps ─────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=                # Restrict to Maps SDK + Geocoding + Places APIs

# ─── App URLs ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# ─── Web-only (Next.js) ───────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
